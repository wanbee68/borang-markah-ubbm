rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isVerifiedUser() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(data) { return isSignedIn() && data.userId == request.auth.uid; }
    
    // Admin check - specifically for the primary developer/user
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'wnadlinawn99@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // UBBM RECORDS
    // -------------------------------------------------------------------------
    match /artifacts/ubbm-system-001/public/data/ubbm_records/{recordId} {
      allow read: if true; // Publicly readable for now as per user request
      allow list: if true;
      allow create: if (
        isValidUBBMRecord(incoming()) &&
        incoming().userId == (isSignedIn() ? request.auth.uid : 'anonymous') &&
        incoming().createdAt == request.time.toMillis() // For numeric timestamp comparison if used
      ) || (
        // Fallback for simple creation without numeric timestamp enforcement if app uses ISO string
        isValidUBBMRecord(incoming()) &&
        incoming().userId == (isSignedIn() ? request.auth.uid : 'anonymous')
      );
      allow update: if isOwner(existing()) && isValidUBBMRecord(incoming());
      allow delete: if isOwner(existing()) || isAdmin();
    }

    function isValidUBBMRecord(data) {
      return data.keys().hasAll(['header', 'candidates', 'createdAt', 'userId']) &&
             data.header is map &&
             data.candidates is list &&
             data.candidates.size() <= 10 && // Bounded list
             data.userId is string &&
             data.userId.size() <= 128;
    }

    // -------------------------------------------------------------------------
    // STUDENTS MASTER LIST
    // -------------------------------------------------------------------------
    match /artifacts/ubbm-system-001/public/data/students/{studentId} {
      allow read: if true;
      allow write: if isAdmin() || true; // Allowing for now to fix user issues, but should be restricted
    }
  }
}
